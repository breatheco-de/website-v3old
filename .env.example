# ─── MCP Server ───────────────────────────────────────────────────────────────

# REQUIRED. Internal loopback credential used exclusively by the MCP server to
# authenticate its own server-to-server requests to the main app's
# /api/auth/check-capability endpoint. It is NOT accepted as an inbound caller
# credential — callers must use OAuth or a Breathecode token.
# The server will exit with a FATAL error at startup if this is not set.
MCP_SERVER_SECRET=change-me-to-a-long-random-string

# LEGACY ALIAS — rename to MCP_SERVER_SECRET for new deployments.
# A deprecation warning is emitted at startup when only this is set.
# MCP_API_KEY=change-me-to-a-long-random-string

# Port the MCP server listens on (default: 3001).
# MCP_PORT=3001

# ─── OAuth (optional — only needed for the legacy static-client OAuth flow) ───

# Static OAuth Client ID/Secret for a pre-registered client.
# Not required when using Claude.ai dynamic client registration (RFC 7591).
# OAUTH_CLIENT_ID=
# OAUTH_CLIENT_SECRET=

# ─── App / deployment ─────────────────────────────────────────────────────────

# Public base URL advertised in OAuth metadata and used for canonical URLs.
# On Replit this is auto-resolved from REPLIT_DEV_DOMAIN — only set it here
# when deploying outside Replit or when you need to force a specific URL.
# SITE_URL=https://your-project.replit.app

# Port the main Express app listens on (default: 5000).
# PORT=5000
