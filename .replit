modules = ["nodejs-20", "web", "python-3.11", "postgresql-16"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"
packages = ["imagemagick", "libwebp", "unzip"]

[deployment]
deploymentTarget = "vm"
build = ["sh", "-c", "npm run build && node_modules/.bin/esbuild mcp-server/index.ts --platform=node --packages=external --bundle --format=esm --outfile=dist/mcp-server.js"]
run = ["sh", "-c", "node dist/mcp-server.js & node dist/index.js"]

[[ports]]
localPort = 3001
externalPort = 3003

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 6333
externalPort = 6000

[[ports]]
localPort = 6334
externalPort = 6800

[[ports]]
localPort = 19998
externalPort = 4200

[[ports]]
localPort = 19999
externalPort = 5000

[[ports]]
localPort = 23636
externalPort = 3001

[[ports]]
localPort = 23637
externalPort = 3000

[[ports]]
localPort = 23638
externalPort = 3002

[env]
PORT = "5000"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/mockup-sandbox: Component Preview Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "MCP Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Qdrant Vector Store"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "artifacts/mockup-sandbox: Component Preview Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/mockup-sandbox && PORT=23636 BASE_PATH=/__mockup/ npm run dev"
waitForPort = 23636

[workflows.workflow.metadata]
outputType = "console"
isCanvasWorkflow = true

[[workflows.workflow]]
name = "MCP Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "tsx mcp-server/index.ts"
waitForPort = 3001

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Qdrant Vector Store"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/start-qdrant.sh"

[workflows.workflow.metadata]
outputType = "console"

[agent]
integrations = ["javascript_openai_ai_integrations:1.0.0"]
expertMode = true

