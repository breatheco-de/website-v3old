      "example": "hero program page",
      "importYaml": "- type: hero\n  version: '1.0'\n  variant: course\n  title: Stay Relevant in Your Career. Lead with AI.\n  title_highlight: Lead with AI\n  subtitle: Gain the AI skills to stay competitive and advance your career in just 6 weeks. Learn to apply AI at work for greater efficiency, creativity, and impact.\n  students_enrolled:\n    avatars:\n      - https://storage.googleapis.com/4geeks-academy-website/media/coimbra_1764725341501.png\n      - https://storage.googleapis.com/4geeks-academy-website/media/AlexandraEspinoza_1764725386161.jpeg\n      - https://storage.googleapis.com/4geeks-academy-website/media/JeanSt.Cloud_1764725356935.jpeg\n      - https://storage.googleapis.com/4geeks-academy-website/media/MaiLinh2_1770856306817.webp\n    count: +6000 graduates\n  bullet_points:\n    - Learn practical AI skills you can apply immediately in your current role or business workflows.\n    - Use AI to improve productivity, creativity, decision-making, and day-to-day execution at work.\n    - Build confidence using modern AI tools in real professional contexts, not just theory.\n    - Hyper-personalized learning with unlimited 1:1 mentorship and support that continues beyond the program.\n    - Ideal for professionals looking to stay relevant in an AI-powered job market.\n  tutors:\n    - name: Marco Gonzalo\n      role: Main Instructor\n      image: https://storage.googleapis.com/4geeks-academy-website/media/410890.jpg\n    - name: Rigo\n      role: AI Tutor\n      image: https://storage.googleapis.com/4geeks-academy-website/media/rigobot-logo_1764707022198.webp\n  tutors_label: 'Your support system:'\n  media:\n    type: video\n    src: https://www.youtube.com/watch?v=E9RpwJhJi-k\n    thumbnail: https://images.unsplash.com/photo-1677442136019-21780ecad995?w=800&h=450&fit=crop\n    alt: Artificial Intelligence for Professionals program introduction\n  signup_card:\n    title: Download Course Details\n    description: Receive the full course overview, learning structure, schedule, and the practical AI skills you’ll develop in just 6 weeks.\n    cta_button:\n      text: Download Course Details\n      url: '#modal-o9bufw'\n      variant: primary\n    login_link:\n      text: Already a student? Login here.\n      url: https://4geeks.com/login\n    features:\n      - icon: calendar\n        text: 6-Week Professional AI Program\n      - icon: IconRobot\n        text: Practical AI Skills for Real Work\n      - icon: IconBriefcase\n        text: Career-Relevant, Productivity-Focused Training\n      - icon: IconUsers\n        text: Hyper-Personalized Learning Experience\n      - icon: IconUserCheck\n        text: Unlimited 1:1 Mentorship\n      - icon: book\n        text: Real-World AI Applications\n  section_id: hero-74qn9v\n  paddingY:\n    desktop: md\n  marginY:\n    desktop: none\n",
